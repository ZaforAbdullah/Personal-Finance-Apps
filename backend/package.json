{
  "name": "finance-app-backend",
  "version": "1.0.0",
  "description": "Personal Finance App Backend - Fastify + GraphQL + Sequelize",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/migrate.ts",
    "db:seed": "ts-node src/seed.ts",
    "db:reset": "ts-node src/migrate.ts --reset && ts-node src/seed.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "graphql": "^16.8.1",
    "mercurius": "^13.3.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "pino-pretty": "^10.3.1",
    "reflect-metadata": "^0.2.1",
    "sequelize": "^6.35.2",
    "sequelize-typescript": "^2.1.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/sequelize": "^4.28.19",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
